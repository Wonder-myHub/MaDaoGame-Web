{
  "name": "madao-game-docs",
  "version": "1.0.0",
  "description": "MaDaoGame 多人回合制网页对战游戏 - 技术文档站",
  "private": true,
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:stop": "for /f \"tokens=5\" %a in ('netstat -ano ^| findstr :5173') do taskkill /f /pid %a",
    "dev:all": "concurrently -n game,docs -c blue,green \"mvn spring-boot:run\" \"npm run docs:dev\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "mermaid": "^11.16.0",
    "vitepress": "^1.6.3",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
